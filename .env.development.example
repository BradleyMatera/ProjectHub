# Development / staging environment for ProjectHub/Scout
# Copy this file to .env on the dev GCP VM or use it locally.
# Never commit .env to Git.

PORT=3000

# Knowledge base served from the develop branch of the production repo
KNOWLEDGE_URL=https://raw.githubusercontent.com/BradleyMatera/ProjectHub/develop/data/recruiter-knowledge.json

# Origins allowed to call the dev chat API (includes local dev and the staging Pages site)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000,https://bradleymatera.github.io,https://bradleymatera.github.io/ProjectHub-dev

# Free multi-provider LLM routing order
PROVIDER_ORDER=groq,cloudflare,github,gemini,grok

# Generation / request budgets
GEN_TIMEOUT_MS=13000
GEN_MODEL=smollm2:135m
GEN_ENABLED=true
RATE_LIMIT_MAX=20

# Persistent state files (development / staging)
# These are isolated from production stats.json and learned.json
STATS_FILE=stats-dev.json
LEARNED_FILE=learned-dev.json

# Think Mode (self-improvement)
# In dev/staging, keep pushes OFF so learned answers are sandboxed in learned-dev.json.
# Review them manually before enabling push to the production knowledge base.
THINK_PUSH_ENABLED=false
# If you later want dev to push to a staging knowledge file, point it at ProjectHub-dev:
# THINK_REPO_OWNER=BradleyMatera
# THINK_REPO_NAME=ProjectHub-dev
# THINK_KNOWLEDGE_PATH=data/recruiter-knowledge.json

# Provider credentials
# Use the same keys as production OR use separate dev keys with lower quotas.
GROQ_API_KEY=
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
GITHUB_MODELS_TOKEN=
GEMINI_API_KEY=
XAI_API_KEY=

# Lower daily limits recommended for dev to avoid burning production quotas during testing
GROQ_DAILY_LIMIT=100
CLOUDFLARE_DAILY_LIMIT=50
GITHUB_DAILY_LIMIT=25
GEMINI_DAILY_LIMIT=150
XAI_DAILY_LIMIT=50
