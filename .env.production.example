# Production environment for ProjectHub/Scout
# Copy this file to .env on the live GCP VM and fill in the real values.
# Never commit .env to Git.

PORT=3000

KNOWLEDGE_URL=https://raw.githubusercontent.com/BradleyMatera/ProjectHub/master/data/recruiter-knowledge.json

ALLOWED_ORIGINS=https://bradleymatera.dev,https://www.bradleymatera.dev,https://bradleymatera.github.io

PROVIDER_ORDER=groq,cloudflare,github,gemini,grok

GEN_TIMEOUT_MS=13000
GEN_MODEL=smollm2:135m
GEN_ENABLED=true
RATE_LIMIT_MAX=20

STATS_FILE=stats.json
LEARNED_FILE=learned.json

# Cost ledger (disabled by default in production to keep the VM minimal)
COST_TRACKER=false
# COST_FILE=costs.json

# Think Mode (self-improvement)
# These default to the production repo if unset.
THINK_PUSH_ENABLED=true
THINK_REPO_OWNER=BradleyMatera
THINK_REPO_NAME=ProjectHub
THINK_KNOWLEDGE_PATH=data/recruiter-knowledge.json

GROQ_API_KEY=
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
GITHUB_MODELS_TOKEN=
GEMINI_API_KEY=
XAI_API_KEY=
