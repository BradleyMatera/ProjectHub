# Production environment for ProjectHub/Scout
# Copy this file to .env on the live GCP VM and fill in the real values.
# Never commit .env to Git.

PORT=3000

KNOWLEDGE_URL=https://raw.githubusercontent.com/BradleyMatera/ProjectHub/master/data/recruiter-knowledge.json

ALLOWED_ORIGINS=https://bradleymatera.dev,https://www.bradleymatera.dev,https://bradleymatera.github.io

PROVIDER_ORDER=groq,cloudflare,github,gemini,grok

GEN_TIMEOUT_MS=13000
GEN_MODEL=smollm2:135m
GEN_ENABLED=true
RATE_LIMIT_MAX=20

STATS_FILE=stats.json
LEARNED_FILE=learned.json

GITHUB_REPO_OWNER=BradleyMatera
GITHUB_REPO_NAME=ProjectHub

GROQ_API_KEY=
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
GITHUB_MODELS_TOKEN=
GEMINI_API_KEY=
XAI_API_KEY=
