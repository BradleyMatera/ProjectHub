{
  "name": "projecthub",
  "version": "1.0.0",
  "description": "Free embeddable AI recruiter assistant widget using a multi-provider LLM network and grounded RAG",
  "main": "ProjectHub.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "reset-stats": "node scripts/reset-stats.js",
    "reset-stats:remote": "node scripts/reset-stats.js --remote",
    "judge-poc": "node scripts/think-judge-poc.js",
    "test": "node --test test/**/*.test.js",
    "test:ledger": "node --test test/cost-ledger.test.js test/cost-insights.test.js",
    "test:retrieval": "node --test test/bm25.test.js test/query-understanding.test.js test/vector-index.test.js test/hybrid-retrieve.test.js",
    "build:embeddings": "node scripts/build-embeddings.js",
    "eval-retrieval": "node scripts/eval-retrieval.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/BradleyMatera/ProjectHub.git"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/BradleyMatera/ProjectHub/issues"
  },
  "homepage": "https://bradleymatera.github.io/ProjectHub/",
  "devDependencies": {
    "vite": "^8.1.4"
  },
  "dependencies": {
    "@carbon/charts": "^1.22.0",
    "@carbon/styles": "^1.67.0",
    "@carbon/web-components": "^2.18.0"
  }
}
